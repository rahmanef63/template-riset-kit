# Convex (self-hosted or cloud) — set BOTH in Vercel.
NEXT_PUBLIC_CONVEX_URL=
# Production deploy key from Convex (Settings -> Deploy Keys). Lets the Vercel
# build push functions+schema to Convex (build:auto) and auto-provision auth keys.
CONVEX_DEPLOY_KEY=

# @convex-dev/auth — required for auth signing. AUTO-SET during build by
# scripts/setup-auth.mjs when CONVEX_DEPLOY_KEY is present (you usually don't
# touch these). Listed here for local dev / manual fallback.
JWKS=
JWT_PRIVATE_KEY=
SITE_URL=http://localhost:3000

# In-app update channel (optional) — set on your CONVEX deployment to enable the
# admin "Rebuild now" button. Create at Vercel -> Settings -> Git -> Deploy Hooks.
VERCEL_DEPLOY_HOOK_URL=

# Demo stage flag — leave UNSET on your own clone. Only the public showcase sets
# NEXT_PUBLIC_DEMO=1, which reveals the "Deploy your own" button. Your clone won't.
# NEXT_PUBLIC_DEMO=
# NEXT_PUBLIC_CLONE_URL=   # optional: override the Vercel deploy/clone link

# Admin signup gate — set this on your CONVEX deployment (npx convex env set
# ADMIN_SIGNUP_KEY <random>). Without the matching key, NOBODY can register an
# admin account. It is your one-time onboarding token. NOT a NEXT_PUBLIC_ var —
# keep it server-side only, never expose to the browser.
ADMIN_SIGNUP_KEY=

# Zero-touch admin (optional) — set BOTH on your CONVEX deployment to auto-create
# the owner account on first load. You then sign in with these. Once an owner
# exists they are ignored. Server-side only (Convex env), never NEXT_PUBLIC_.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Server actions encryption (multi-instance — pin once, share across instances)
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Optional OAuth providers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
