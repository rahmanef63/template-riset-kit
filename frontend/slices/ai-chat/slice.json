{
  "$schema": "https://resource.rahmanef.com/slice-schema.json",
  "slug": "ai-chat",
  "version": "0.1.0",
  "category": "ai",
  "kind": "full",
  "title": "AI Chat — Workbench / Sidebar / Search",
  "description": "Claude.ai / ChatGPT-style chatbot. Three-column shell: threads + attachments + active tools on the left, streaming messages in the center, model picker + params + skills + actions on the right. Multi-provider, multimodal, typed tool calls, agent mode, branching threads, RAG citations, resumable streams.",
  "namespace": "@/features/ai-chat",
  "convex": {
    "tablesExport": "aiChatTables",
    "schemaPath": "convex/features/ai-chat/_schema.ts",
    "rootPaths": ["convex/features/ai-chat"]
  },
  "frontend": {
    "slicePath": "frontend/slices/ai-chat",
    "configExport": ""
  },
  "deps": {
    "npm": [
      "ai@^4.0.0",
      "@ai-sdk/anthropic@^0.0.50",
      "@ai-sdk/openai@^0.0.60"
    ],
    "shadcn": [
      "button", "card", "badge", "avatar", "scroll-area",
      "select", "separator", "slider", "switch", "textarea", "tabs"
    ],
    "env": [
      { "name": "ANTHROPIC_API_KEY", "scope": "convex" },
      { "name": "OPENAI_API_KEY", "scope": "convex" },
      { "name": "GOOGLE_GENERATIVE_AI_API_KEY", "scope": "convex" }
    ],
    "peers": [
      { "slug": "convex-auth", "range": "^0.1" },
      { "slug": "ai-router", "range": "^0.1" },
      { "slug": "ai-admin", "range": "^0.1" },
      { "slug": "vector-search", "range": "^0.1" }
    ]
  },
  "registers": [],
  "audit": [],
  "license": "MIT",
  "tags": [
    "ai", "ai:chatbot", "streaming", "multimodal", "tool-calls",
    "agent-mode", "rag", "citations", "branching", "history"
  ]
}
